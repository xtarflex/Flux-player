{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flux",
  "version": "0.2.0-beta.1",
  "identifier": "com.sunny.flux-player",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Flux",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "devtools": true
      },
      {
        "label": "hud",
        "title": "Flux HUD",
        "url": "/hud",
        "width": 380,
        "height": 100,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "focus": false,
        "resizable": false,
        "fullscreen": false,
        "shadow": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' http://asset.localhost https://asset.localhost asset: blob: data:; media-src 'self' http://asset.localhost https://asset.localhost asset:; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' https://* http://*;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$DOCUMENTS/**", "$DOWNLOADS/**", "$MUSIC/**", "$PICTURES/**", "$VIDEOS/**", "$HOME/**", "C:/**", "D:/**", "E:/**", "F:/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "licenseFile": "assets/LICENSE_NSIS.txt",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "sidebarImage": "assets/installer-banner.bmp",
        "displayLanguageSelector": true
      }
    }
  }
}
